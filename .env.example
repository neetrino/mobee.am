# Application
NODE_ENV="development"
APP_URL="http://localhost:3000"
# Same Next.js app (Route Handlers under /api): leave empty.
# Separate API host only: https://api.example.com
NEXT_PUBLIC_API_URL=""
# If set to true, ignores NEXT_PUBLIC_API_URL (useful when Vercel still has an old API URL).
# This repo sets it in vercel.json for production deploys.
NEXT_PUBLIC_SAME_ORIGIN_API=""


# ——— Database (Neon PostgreSQL) ———
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""


# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"




# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="test@neetrino.com"

# ——— File storage (Cloudflare R2) ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# After `pnpm run upload:product-card-image-r2` — public URL of static/product-card-display.png
# NEXT_PUBLIC_PRODUCT_CARD_DISPLAY_IMAGE_URL="https://your-bucket.r2.dev/static/product-card-display.png"

# ——— Figma (MCP) ———
FIGMA_ACCESS_TOKEN=""

# ——— Payments (Idram / Armenian bank) ———
# IDRAM_GATEWAY_BASE_URL="https://payments.example.com/idram"
# IDRAM_MERCHANT_ID=""
# IDRAM_SECRET_KEY=""
# ARCA_GATEWAY_BASE_URL="https://payments.example.com/arca"
# ARCA_MERCHANT_ID=""
# ARCA_SECRET_KEY=""

# ——— Optional ———
# NEXT_PUBLIC_APP_URL="http://localhost:3000" # Legacy fallback; prefer APP_URL
# CORS_ORIGIN="https://your-domain.com,https://preview-your-domain.com"  # Comma-separated allowed browser origins; APP_URL is added automatically
# SENTRY_DSN=""
# Google Maps / Mapbox for Contact page
# MAPBOX_PUBLIC_KEY=""