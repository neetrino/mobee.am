## 🌐 NEXT.JS APP ROUTER

### Server Components (լռելյայն)

```tsx
// app/products/page.tsx — Server Component
import { ProductList } from '@/features/products';
import { getProducts } from '@/lib/api';

// Async կոմպոնենտ — տվյալները սերվերում
export default async function ProductsPage() {
  const products = await getProducts();
  
  return (
    <main className="container py-8">
      <h1 className="text-3xl font-bold mb-8">Կատալոգ</h1>
      <ProductList products={products} />
    </main>
  );
}
```

### Client Components (երբ ինտերակտիվություն է պետք)

```tsx
// features/products/components/ProductFilters.tsx
'use client';

import { useState } from 'react';
import { useRouter, useSearchParams } from 'next/navigation';

export function ProductFilters() {
  const router = useRouter();
  const searchParams = useSearchParams();
  const [category, setCategory] = useState(searchParams.get('category') ?? '');
  
  const handleFilter = () => {
    const params = new URLSearchParams(searchParams);
    params.set('category', category);
    router.push(`?${params.toString()}`);
  };
  
  return (
    <div className="flex gap-4">
      <select 
        value={category} 
        onChange={(e) => setCategory(e.target.value)}
      >
        <option value="">Բոլոր կատեգորիաները</option>
        <option value="electronics">Էլեկտրոնիկա</option>
      </select>
      <button onClick={handleFilter}>Կիրառել</button>
    </div>
  );
}
```

### Երբ օգտագործել 'use client'

```tsx
// ✅ 'use client' պետք է.
// - useState, useEffect, useContext
// - Event handlers (onClick, onChange)
// - Browser APIs (localStorage, window)
// - Կաստոմ հուկեր վիճակով
// - Միայն բրաուզերի գրադարաններ

// ❌ 'use client' ՊԵՏՔ ՉԷ.
// - Ստատիկ ռենդեր
// - Տվյալների fetch
// - Ուղղակի ԲԴ-ի մուտք
// - Server Actions
```

### Server Actions

```tsx
// app/actions/products.ts
'use server';

import { revalidatePath } from 'next/cache';
import { db } from '@/lib/db';

export async function createProduct(formData: FormData) {
  const name = formData.get('name') as string;
  const price = Number(formData.get('price'));
  
  await db.product.create({
    data: { name, price },
  });
  
  revalidatePath('/products');
}

// Օգտագործում կոմպոնենտում
// app/products/new/page.tsx
import { createProduct } from '../actions/products';

export default function NewProductPage() {
  return (
    <form action={createProduct}>
      <input name="name" required />
      <input name="price" type="number" required />
      <button type="submit">Ստեղծել</button>
    </form>
  );
}
```

