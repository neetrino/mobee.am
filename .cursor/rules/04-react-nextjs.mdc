## 🚫 ԱՆՏԻՊԱՏԵՐՆԵՐ

### Խուսափի՛ր prop drilling-ից

```tsx
// ❌ ՎԱՏ — user-ը փոխանցում ենք բոլոր մակարդակներով
function App() {
  const user = useUser();
  return <Layout user={user}><Page user={user}><Component user={user} /></Page></Layout>;
}

// ✅ ԼԱՎ — Context կամ հուկ
function Component() {
  const user = useUser(); // հուկը ստանում է կոնտեքստից
  return <div>{user.name}</div>;
}
```

### Խուսափի՛ր inline օբյեկտներից prop-ներում

```tsx
// ❌ ՎԱՏ — ամեն ռենդերին նոր օբյեկտ
<Component style={{ color: 'red' }} />
<Component config={{ theme: 'dark', size: 'lg' }} />

// ✅ ԼԱՎ — կայուն հղում
const style = { color: 'red' };
const config = useMemo(() => ({ theme: 'dark', size: 'lg' }), []);

<Component style={style} />
<Component config={config} />
```

### Խուսափի՛ր անանուն ֆունկցիաներից ռենդերում

```tsx
// ❌ ՎԱՏ — ամեն ռենդերին նոր ֆունկցիա
{items.map(item => (
  <Item key={item.id} onClick={() => handleClick(item.id)} />
))}

// ✅ ԼԱՎ — useCallback կամ տեղափոխի՛ր կոմպոնենտ
const handleItemClick = useCallback((id: string) => {
  // ...
}, []);

{items.map(item => (
  <Item key={item.id} id={item.id} onClick={handleItemClick} />
))}

// Կամ կոմպոնենտն ինքը մշակում է
function Item({ item, onClick }: ItemProps) {
  const handleClick = () => onClick(item.id);
  return <div onClick={handleClick}>{item.name}</div>;
}
```

